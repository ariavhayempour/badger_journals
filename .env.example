# Neon Postgres connection string (injected as a Vercel env secret in production).
# Copy to .env for local use. Never commit a real value — .env / .env.* are gitignored.
DATABASE_URL=postgres://USER:PASSWORD@HOST/DB?sslmode=require

# Clerk (hosted admin auth). Copy real values from the Clerk Dashboard into .env.
# The publishable key is public (PUBLIC_ is exposed to the client); the secret key is server-only.
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Canonical sign-in path — the embedded admin login. No sign-up var: admins are
# provisioned via Clerk Restricted mode, so no public self-serve sign-up exists.
PUBLIC_CLERK_SIGN_IN_URL=/admin/login

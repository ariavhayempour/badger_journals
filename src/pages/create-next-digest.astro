---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import InquiryForm from '../components/InquiryForm.astro';
import { researchAreas } from '../data/research-areas';
---
<BaseLayout
  title="Create the Next Digest"
  description="Badger Journals is expanding — help launch a student-written digest in a new field of science."
  path="/create-next-digest"
>
  <h1>Create the Next Digest</h1>
  <p>
    Badger Journals is expanding. We believe every area of science deserves accessible
    student-written reviews. If you are passionate about a research area, we want to
    help you build the next Badger Journals digest.
  </p>

  <section>
    <h2>Research Areas We're Expanding Into</h2>
    <p>
      Our model of student-driven science communication is proven. Now we're looking
      for passionate students to launch new digests in other cutting-edge fields.
    </p>
    <ul class="areas">
      {researchAreas.map((a) => (
        <li>
          <p class="icon" aria-hidden="true">{a.icon}</p>
          <h3>{a.title}</h3>
          <p>{a.description}</p>
        </li>
      ))}
      <li>
        <p class="icon" aria-hidden="true">✨</p>
        <h3>Your Field</h3>
        <p>
          Passionate about a research area not listed here? We want to hear from you.
          Any field of science is welcome at Badger Journals.
        </p>
        <a href="/contact">Get in touch →</a>
      </li>
    </ul>
  </section>

  <section>
    <h2>Propose a Digest</h2>
    <p>Have a field in mind? Pitch it to us and we'll help you get started.</p>
    <InquiryForm type="digest" />
  </section>
</BaseLayout>
<style>
  .areas {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
    gap: var(--space-6);
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .areas li {
    padding: var(--space-6);
    background: var(--color-paper-muted);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius);
  }
  .areas .icon {
    margin: 0;
    font-size: var(--step-3);
  }
  .areas h3 {
    margin: var(--space-3) 0 var(--space-3);
    font-family: var(--font-display);
    font-size: var(--step-1);
  }
  .areas p {
    margin: 0;
  }
</style>

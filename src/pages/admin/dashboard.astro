---
// Fresh SSR query per request; auth handled upstream by the /admin gate. See docs/claude/0012-admin-dashboard.md
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import RsvpTable from '../../components/RsvpTable.astro';
import InquiryTable from '../../components/InquiryTable.astro';
import { listRsvps } from '../../db/rsvp';
import { listSubmissions } from '../../db/submission';
import { groupRsvpsByMeeting } from '../../lib/rsvp-grouping';

const [rsvps, submissions] = await Promise.all([listRsvps(), listSubmissions()]);
const groups = groupRsvpsByMeeting(rsvps);
---
<AdminLayout title="Dashboard">
  <h1>Dashboard</h1>

  <section aria-labelledby="rsvps-heading">
    <h2 id="rsvps-heading">RSVPs by meeting</h2>
    <RsvpTable groups={groups} />
  </section>

  <section aria-labelledby="submissions-heading">
    <h2 id="submissions-heading">Submissions</h2>
    <InquiryTable submissions={submissions} />
  </section>
</AdminLayout>

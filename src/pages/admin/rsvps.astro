---
// Per-request SSR read of RSVPs, grouped by meeting. The /admin gate (middleware) covers this route.
export const prerender = false;
import AdminLayout from '../../layouts/AdminLayout.astro';
import PageHeader from '../../components/admin/PageHeader.astro';
import RsvpFilters from '../../components/RsvpFilters.astro';
import RsvpTable from '../../components/RsvpTable.astro';
import { listRsvps } from '../../db/rsvp';
import { listEvents } from '../../db/event';
import { groupRsvpsByMeeting } from '../../lib/rsvp-grouping';

const [rsvps, events] = await Promise.all([listRsvps(), listEvents()]);
const groups = groupRsvpsByMeeting(rsvps);
const today = new Date().toISOString().slice(0, 10);
---
<AdminLayout title="RSVPs" rsvpsCount={rsvps.length}>
  <PageHeader title="RSVPs" subtitle={`${rsvps.length} total across ${groups.length} ${groups.length === 1 ? 'meeting' : 'meetings'}.`} />
  <RsvpFilters groups={groups} events={events} today={today}>
    <button
      slot="action"
      id="edit-rsvps-btn"
      type="button"
      class="text-sm font-semibold text-primary hover:underline cursor-pointer"
    >
      Manage RSVPs
    </button>
  </RsvpFilters>
  <RsvpTable groups={groups} events={events} today={today} />
</AdminLayout>

---
// Per-request SSR; the /admin gate (middleware) covers GET and POST — no in-page auth check.
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import PageHeader from '../../../components/admin/PageHeader.astro';
import Panel from '../../../components/admin/Panel.astro';
import EventForm from '../../../components/EventForm.astro';
import { listEvents, insertEvent, deleteEvent } from '../../../db/event';
import { listRsvps } from '../../../db/rsvp';
import { validateEvent, type EventFieldError, type EventInput } from '../../../lib/event-validation';

let errors: EventFieldError[] = [];
let values: Partial<EventInput> = {};

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = form.get('_action');
  if (action === 'create') {
    const input: EventInput = {
      date: String(form.get('date') ?? ''),
      title: String(form.get('title') ?? ''),
      time: String(form.get('time') ?? ''),
      location: String(form.get('location') ?? ''),
    };
    errors = validateEvent(input);
    if (errors.length === 0) {
      await insertEvent(input);
      return Astro.redirect('/admin/events', 303);
    }
    values = input;
    Astro.response.status = 400;
  } else if (action === 'delete') {
    const id = Number(form.get('id'));
    if (Number.isInteger(id) && id > 0) {
      await deleteEvent(id);
    }
    return Astro.redirect('/admin/events', 303);
  }
}

const [events, rsvps] = await Promise.all([listEvents(), listRsvps()]);
const counts = rsvps.reduce<Record<string, number>>((acc, r) => {
  acc[r.meeting] = (acc[r.meeting] ?? 0) + 1;
  return acc;
}, {});
const dateFmt = new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
const fmtDate = (iso: string) => dateFmt.format(new Date(iso));
const th = 'border-b border-border/60 bg-muted/40 px-5 py-3 text-left text-[0.7rem] font-bold tracking-[0.08em] text-muted-foreground uppercase';
const td = 'border-b border-border/50 px-5 py-3.5 align-middle';
---
<AdminLayout title="Events">
  <PageHeader title="Events" subtitle="Create meetings and manage the schedule. Editing an event is where you can also delete it." />

  <Panel title="Add an event">
    <div class="p-5">
      <EventForm action="/admin/events" actionValue="create" submitLabel="Create event" values={values} errors={errors} />
    </div>
  </Panel>

  <Panel title="All events" count={`${events.length} total`}>
    {events.length === 0 ? (
      <p class="px-5 py-8 text-muted-foreground">No events yet. Add one above.</p>
    ) : (
      <div class="overflow-x-auto">
        <table class="w-full border-collapse text-sm">
          <thead>
            <tr>
              <th scope="col" class={th}>Date</th>
              <th scope="col" class={th}>Title</th>
              <th scope="col" class={th}>Time</th>
              <th scope="col" class={th}>Location</th>
              <th scope="col" class={th}>RSVPs</th>
              <th scope="col" class={`${th} text-right`}>Actions</th>
            </tr>
          </thead>
          <tbody>
            {events.map((e) => (
              <tr class="transition-colors hover:bg-muted/40">
                <td class={`${td} font-serif font-semibold whitespace-nowrap tabular-nums`}><time datetime={e.date}>{fmtDate(e.date)}</time></td>
                <td class={`${td} font-semibold`}>{e.title ?? <span class="font-normal text-muted-foreground">Untitled</span>}</td>
                <td class={`${td} whitespace-nowrap text-muted-foreground`}>{e.time ?? '—'}</td>
                <td class={`${td} text-muted-foreground`}>{e.location ?? '—'}</td>
                <td class={td}>
                  <span class="inline-flex items-center gap-1.5 font-semibold">
                    <span class="size-1.5 rounded-full bg-primary"></span>{counts[e.slug] ?? 0}
                  </span>
                </td>
                <td class={`${td} text-right`}>
                  <a href={`/admin/events/${e.id}`} class="inline-flex h-8 items-center rounded-md border border-border px-3 text-sm font-semibold transition-colors hover:border-primary/40 hover:text-primary">Edit</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </Panel>
</AdminLayout>

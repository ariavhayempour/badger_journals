---
// Per-request SSR; the /admin gate (middleware) covers GET and POST — no in-page auth check.
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import EventForm from '../../../components/EventForm.astro';
import { getEvent, updateEvent } from '../../../db/event';
import { validateEvent, type EventFieldError, type EventInput } from '../../../lib/event-validation';

const idParam = Astro.params.id ?? '';
if (!/^\d+$/.test(idParam)) {
  return new Response('Not found', { status: 404 });
}
const id = Number(idParam);

let errors: EventFieldError[] = [];
let submitted: EventInput | null = null;

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  if (form.get('_action') === 'update') {
    const input: EventInput = {
      date: String(form.get('date') ?? ''),
      title: String(form.get('title') ?? ''),
      time: String(form.get('time') ?? ''),
      location: String(form.get('location') ?? ''),
    };
    errors = validateEvent(input);
    if (errors.length === 0) {
      await updateEvent(id, input);
      return Astro.redirect('/admin/events', 303);
    }
    submitted = input;
    Astro.response.status = 400;
  }
}

const event = await getEvent(id);
if (!event) {
  return new Response('Not found', { status: 404 });
}

const values: Partial<EventInput> = submitted ?? {
  date: event.date,
  title: event.title ?? '',
  time: event.time ?? '',
  location: event.location ?? '',
};
---
<AdminLayout title="Edit event">
  <h1>Edit event</h1>
  <EventForm action={`/admin/events/${id}`} actionValue="update" submitLabel="Save changes" values={values} errors={errors} />
  <p><a href="/admin/events">Back to events</a></p>
</AdminLayout>

---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import { team } from '../data/team';
---
<BaseLayout
  title="Our Team"
  description="The undergraduate students who build Badger Journals across UW-Madison."
  path="/team"
>
  <h1>Our Team</h1>
  {team.map((group) => (
    <section>
      <h2>{group.title}</h2>
      <ul>
        {group.members.map((m) => (
          <li>
            <h3>{m.name}</h3>
            <p>{m.role}</p>
            <p>{m.major}</p>
          </li>
        ))}
      </ul>
    </section>
  ))}
</BaseLayout>
<style>
  section ul {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(15rem, 1fr));
    gap: var(--space-6);
    margin: 0;
    padding: 0;
    list-style: none;
  }
  section li {
    padding: var(--space-6);
    background: var(--color-paper-muted);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius);
  }
  section li h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--step-1);
  }
  section li p {
    margin: 0;
  }
  section li p:first-of-type {
    color: var(--color-cardinal);
    font-weight: 500;
  }
</style>

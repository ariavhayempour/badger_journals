---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { team } from '../data/team';

const initials = (name: string) =>
  name.split(/[\s&]+/).filter(Boolean).slice(0, 2).map((w) => w[0]).join('').toUpperCase();
---
<BaseLayout
  title="Our Team"
  description="The undergraduate students who build Badger Journals across UW-Madison."
  path="/team"
>
  <section class="border-b border-border bg-cream">
    <div class="mx-auto max-w-6xl px-6 py-16 sm:py-20">
      <p class="mb-3 text-xs font-bold tracking-[0.14em] text-primary uppercase">The people</p>
      <h1 class="font-serif text-[clamp(2.4rem,5vw,3.6rem)] leading-[1.05] font-extrabold tracking-tight text-balance">
        Built by Badgers.
      </h1>
      <p class="mt-4 max-w-[60ch] text-lg text-muted-foreground">
        Undergraduates from across UW–Madison, developing real skills in scientific
        writing, critical reading, and research communication.
      </p>
    </div>
  </section>

  <div class="mx-auto max-w-6xl px-6 py-16">
    {team.map((group) => (
      <section class="mt-14 first:mt-0">
        <h2 class="mb-6 flex items-center gap-4 font-serif text-2xl font-bold tracking-tight">
          {group.title}
          <span class="h-px flex-1 bg-border"></span>
        </h2>
        <ul class="grid list-none gap-5 p-0 [grid-template-columns:repeat(auto-fill,minmax(15rem,1fr))]">
          {group.members.filter((m) => m.name !== 'TODO').map((m) => (
            <li class="rounded-2xl border border-border bg-card p-6 text-center transition-shadow hover:shadow-[0_10px_30px_rgb(28_25_23/0.08)]">
              {m.photo ? (
                <Image class="mx-auto mb-4 size-24 rounded-full object-cover" src={m.photo} alt={m.name} width={200} height={200} loading="lazy" />
              ) : (
                <span class="mx-auto mb-4 grid size-24 place-items-center rounded-full border border-border bg-cardinal-tint font-serif text-2xl font-bold text-primary">{initials(m.name)}</span>
              )}
              <h3 class="font-serif text-lg font-semibold leading-tight">{m.name}</h3>
              <p class="mt-1 font-semibold text-primary">{m.role}</p>
              <p class="text-sm text-muted-foreground">{m.major}</p>
            </li>
          ))}
        </ul>
      </section>
    ))}

    <section class="mt-16 rounded-3xl border border-border bg-canvas p-8 sm:p-10">
      <h2 class="font-serif text-2xl font-bold tracking-tight">Join the team</h2>
      <p class="mt-2 max-w-[60ch] text-lg text-muted-foreground">
        Want to write, edit, or design for Badger Journals? Tell us a bit about yourself.
      </p>
      <div class="mt-6">
        <a href="/contact?type=join" class="inline-flex h-10 items-center justify-center rounded-lg bg-primary px-5 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90">
          Contact us to join
        </a>
      </div>
    </section>
  </div>
</BaseLayout>

---
export const prerender = true;
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const DIGEST_LABELS = {
  cardiovascular: 'Cardiovascular Digest',
  cancer: 'Cancer Digest',
  neuroscience: 'Neuroscience Digest',
} as const;

export const getStaticPaths = (async () => {
  const reviews = await getCollection('reviews');
  return reviews.map((review) => ({ params: { slug: review.id }, props: { review } }));
}) satisfies GetStaticPaths;

const { review } = Astro.props;
const { title, authors, date, digest, excerpt } = review.data;
---
<BaseLayout title={title} description={excerpt} path={`/reviews/${review.id}`}>
  <article>
    <p class="tag">{DIGEST_LABELS[digest]}</p>
    <h1>{title}</h1>
    <p class="authors">By {authors.join(', ')} · {date}</p>
    <p>{excerpt}</p>
  </article>
</BaseLayout>

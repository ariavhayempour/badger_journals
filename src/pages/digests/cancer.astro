---
export const prerender = true;
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReviewCard from '../../components/ReviewCard.astro';

const SLUG = 'cancer';
const digest = await getEntry('digests', SLUG);
if (!digest) throw new Error(`Missing digest: ${SLUG}`);
const reviews = (await getCollection('reviews')).filter((r) => r.data.digest === SLUG);
---
<BaseLayout title={digest.data.name} description={digest.data.description} path={`/digests/${SLUG}`}>
  <h1>{digest.data.name}</h1>
  <p>{digest.data.description}</p>
  <ul class="reviews">
    {reviews.map((r) => (
      <li>
        <ReviewCard
          slug={r.id}
          title={r.data.title}
          authors={r.data.authors}
          date={r.data.date}
          digest={r.data.digest}
          excerpt={r.data.excerpt}
        />
      </li>
    ))}
  </ul>
</BaseLayout>

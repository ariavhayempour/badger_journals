---
// Per-request SSR read of the events table, so admin create/edit/delete shows on the next visit with no redeploy.
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';
import RsvpForm from '../components/RsvpForm.astro';
import { listEvents } from '../db/event';
import { splitMeetings, type MeetingView } from '../lib/split-meetings';

const rows = await listEvents();
const view: MeetingView[] = rows.map((r) => ({
  id: r.slug,
  date: r.date,
  title: r.title ?? undefined,
  time: r.time ?? undefined,
  location: r.location ?? undefined,
}));
const today = new Date().toISOString().slice(0, 10); // request time — advances without a redeploy
const { upcoming, past } = splitMeetings(view, today);

// UTC formatter matches the UTC-midnight parse of an ISO date, avoiding an off-by-one day shift.
const dateFmt = new Intl.DateTimeFormat('en-US', { weekday: 'short', month: 'short', day: 'numeric', timeZone: 'UTC' });
const formatDate = (iso: string): string => dateFmt.format(new Date(iso));
const detail = (m: MeetingView): string => [m.time, m.location].filter(Boolean).join(' · ');
---
<BaseLayout
  title="Meetings"
  description="When and where Badger Journals meets, and what to expect."
  path="/meetings"
>
  <section class="border-b border-border bg-cream">
    <div class="mx-auto max-w-5xl px-6 py-16 sm:py-20">
      <p class="mb-3 text-xs font-bold tracking-[0.14em] text-primary uppercase">Meetings</p>
      <h1 class="font-serif text-[clamp(2.4rem,5vw,3.6rem)] leading-[1.05] font-extrabold tracking-tight text-balance">
        Come read with us.
      </h1>
      <p class="mt-4 max-w-[60ch] text-lg text-muted-foreground">
        No prep required — drop in, join the discussion, and RSVP so we know to save you a seat.
      </p>
    </div>
  </section>

  <div class="mx-auto max-w-5xl px-6 py-16">
    {upcoming.length > 0 ? (
      <ul class="grid list-none gap-5 p-0">
        {upcoming.map((m) => (
          <li class="rounded-2xl border border-border bg-card p-6 sm:p-8">
            <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1">
              <time class="font-serif text-xl font-bold tabular-nums text-primary" datetime={m.date}>{formatDate(m.date)}</time>
              {m.title && <p class="font-serif text-xl font-semibold">{m.title}</p>}
            </div>
            {detail(m) && <p class="mt-1 text-muted-foreground">{detail(m)}</p>}
            <RsvpForm meeting={m.id} />
          </li>
        ))}
      </ul>
    ) : (
      <p class="rounded-2xl border border-border bg-card p-8 text-lg text-muted-foreground">
        Stay tuned for upcoming meetings!
      </p>
    )}

    {past.length > 0 && (
      <section class="mt-16">
        <h2 class="mb-6 flex items-center gap-4 font-serif text-2xl font-bold tracking-tight text-muted-foreground">
          Past meetings
          <span class="h-px flex-1 bg-border"></span>
        </h2>
        <ul class="grid list-none gap-3 p-0">
          {past.map((m) => (
            <li class="flex flex-wrap items-baseline gap-x-4 gap-y-1 rounded-xl border border-border bg-canvas px-5 py-4">
              <time class="font-serif font-semibold tabular-nums text-muted-foreground" datetime={m.date}>{formatDate(m.date)}</time>
              {m.title && <p class="font-medium">{m.title}</p>}
              {detail(m) && <p class="text-sm text-muted-foreground">{detail(m)}</p>}
            </li>
          ))}
        </ul>
      </section>
    )}
  </div>
</BaseLayout>

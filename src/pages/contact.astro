---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import InquiryForm from '../components/InquiryForm.astro';
---
<BaseLayout
  title="Contact Us"
  description="Get involved with Badger Journals or propose a new digest."
  path="/contact"
>
  <section class="border-b border-border bg-cream">
    <div class="mx-auto max-w-4xl px-6 py-16 sm:py-20">
      <p class="mb-3 text-xs font-bold tracking-[0.14em] text-primary uppercase">Contact</p>
      <h1 class="font-serif text-[clamp(2.4rem,5vw,3.6rem)] leading-[1.05] font-extrabold tracking-tight text-balance">
        Get in touch.
      </h1>
    </div>
  </section>

  <div class="mx-auto max-w-2xl px-6 py-16">
    <section>
      <h2 class="font-serif text-2xl font-bold tracking-tight">Send us a message</h2>
      <p class="mt-2 text-lg text-muted-foreground">
        Whether you want to join our team, start a new digest, or just say hello — we'd love to hear from you.
      </p>
      <InquiryForm />
    </section>
  </div>
</BaseLayout>

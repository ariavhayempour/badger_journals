---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Contact Us"
  description="Get involved with Badger Journals or propose a new digest."
  path="/contact"
>
  <h1>Contact Us</h1>

  <section>
    <h2>Get Involved</h2>
    <p>
      Interested in joining Badger Journals? Reach out and we'll be in touch about how
      to get involved.
    </p>
  </section>

  <section>
    <h2>Start a New Digest</h2>
    <p>Want to launch a new Badger Journals digest? Let us know.</p>
  </section>
</BaseLayout>

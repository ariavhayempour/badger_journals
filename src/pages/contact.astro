---
export const prerender = true;
import BaseLayout from '../layouts/BaseLayout.astro';
import InquiryForm from '../components/InquiryForm.astro';
---
<BaseLayout
  title="Contact Us"
  description="Get involved with Badger Journals or propose a new digest."
  path="/contact"
>
  <h1>Contact Us</h1>

  <section>
    <h2>Get Involved</h2>
    <p>
      Interested in joining Badger Journals? Reach out and we'll be in touch about how
      to get involved.
    </p>
    <InquiryForm type="inquiry" />
  </section>

  <section>
    <h2>Start a New Digest</h2>
    <p>
      Want to launch a new Badger Journals digest?
      <a href="/create-next-digest">Start a new digest →</a>
    </p>
  </section>
</BaseLayout>

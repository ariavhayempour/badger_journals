---
const DIGEST_LABELS = {
  cardiovascular: 'Cardiovascular Digest',
  cancer: 'Cancer Digest',
  neuroscience: 'Neuroscience Digest',
} as const;

interface Props {
  slug: string;
  title: string;
  authors: string[];
  date: string;
  digest: keyof typeof DIGEST_LABELS;
  excerpt: string;
}
const { slug, title, authors, date, digest, excerpt } = Astro.props;
---
<article>
  <p class="tag">{DIGEST_LABELS[digest]}</p>
  <h3><a href={`/reviews/${slug}`}>{title}</a></h3>
  <p class="authors">By {authors.join(', ')} · {date}</p>
  <p class="excerpt">{excerpt}</p>
</article>
<style>
  article {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    height: 100%;
    padding: var(--space-6);
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  article:hover {
    border-color: var(--color-cardinal);
    box-shadow: var(--shadow-1);
  }
  h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--step-2);
    line-height: 1.25;
  }
  h3 a {
    text-decoration: none;
  }
  .excerpt {
    margin: 0;
  }
</style>

---
import type { MeetingGroup } from '../lib/rsvp-grouping';
import Badge from './admin/Badge.astro';

interface Props {
  groups: MeetingGroup[];
}
const { groups } = Astro.props;

const formatTimestamp = (iso: string): string =>
  new Date(iso).toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short' });
---
{
  groups.length === 0 ? (
    <p class="rounded-2xl border border-border bg-card p-8 text-muted-foreground">No RSVPs yet.</p>
  ) : (
    groups.map((group) => (
      <section class="mb-6 overflow-hidden rounded-2xl border border-border bg-card shadow-xs">
        <div class="flex flex-wrap items-center justify-between gap-3 border-b border-border/60 px-5 py-4">
          <h3 class="font-serif text-lg font-bold">{group.meeting}</h3>
          <span class="text-sm text-muted-foreground">{group.rsvps.length} {group.rsvps.length === 1 ? 'guest' : 'guests'}</span>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full border-collapse text-sm">
            <thead>
              <tr>
                <th scope="col" class="border-b border-border/60 bg-muted/40 px-5 py-3 text-left text-[0.7rem] font-bold tracking-[0.08em] text-muted-foreground uppercase">Name</th>
                <th scope="col" class="border-b border-border/60 bg-muted/40 px-5 py-3 text-left text-[0.7rem] font-bold tracking-[0.08em] text-muted-foreground uppercase">Email</th>
                <th scope="col" class="border-b border-border/60 bg-muted/40 px-5 py-3 text-left text-[0.7rem] font-bold tracking-[0.08em] text-muted-foreground uppercase">Status</th>
                <th scope="col" class="border-b border-border/60 bg-muted/40 px-5 py-3 text-left text-[0.7rem] font-bold tracking-[0.08em] text-muted-foreground uppercase">RSVP'd</th>
              </tr>
            </thead>
            <tbody>
              {group.rsvps.map((rsvp) => (
                <tr class="transition-colors hover:bg-muted/40">
                  <td class="border-b border-border/50 px-5 py-3.5 font-semibold">{rsvp.name}</td>
                  <td class="border-b border-border/50 px-5 py-3.5 text-muted-foreground">{rsvp.email}</td>
                  <td class="border-b border-border/50 px-5 py-3.5"><Badge variant="confirmed">Confirmed</Badge></td>
                  <td class="border-b border-border/50 px-5 py-3.5 text-muted-foreground">{formatTimestamp(rsvp.created_at)}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    ))
  )
}

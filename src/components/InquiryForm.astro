---
import type { SubmissionType } from '../db/schema';
import { MAX_NAME, MAX_EMAIL, MAX_MESSAGE } from '../lib/limits';

interface Props {
  type: SubmissionType; // discriminates the placement; also namespaces element ids so forms coexist
}
const { type } = Astro.props;
const nameId = `inq-name-${type}`;
const emailId = `inq-email-${type}`;
const messageId = `inq-message-${type}`;
const nameErrId = `inq-name-err-${type}`;
const emailErrId = `inq-email-err-${type}`;
const messageErrId = `inq-message-err-${type}`;
const statusId = `inq-status-${type}`;
---
<form class="inquiry" method="post" action="/api/inquiry" novalidate data-inquiry>
  <div class="inquiry__field">
    <label for={nameId}>Name</label>
    <input id={nameId} name="name" type="text" autocomplete="name" required maxlength={MAX_NAME} aria-describedby={nameErrId} />
    <p class="inquiry__error" id={nameErrId} data-error-for="name" hidden></p>
  </div>

  <div class="inquiry__field">
    <label for={emailId}>Email (@wisc.edu)</label>
    <input id={emailId} name="email" type="email" autocomplete="email" required maxlength={MAX_EMAIL} aria-describedby={emailErrId} />
    <p class="inquiry__error" id={emailErrId} data-error-for="email" hidden></p>
  </div>

  <div class="inquiry__field">
    <label for={messageId}>Message</label>
    <textarea id={messageId} name="message" rows="5" required maxlength={MAX_MESSAGE} aria-describedby={messageErrId}></textarea>
    <p class="inquiry__error" id={messageErrId} data-error-for="message" hidden></p>
  </div>

  <input type="hidden" name="type" value={type} />

  <div class="inquiry__hp" aria-hidden="true">
    <input type="text" name="company" tabindex="-1" autocomplete="off" aria-hidden="true" />
  </div>

  <button type="submit">Send</button>

  <p class="inquiry__status" id={statusId} role="status" aria-live="polite" data-status hidden></p>
</form>

<script>
  import { validateSubmission, type SubmissionField } from '../lib/submission-validation';
  import type { SubmissionType } from '../db/schema';

  type ApiError = { field: SubmissionField; message: string };

  function setError(form: HTMLFormElement, field: SubmissionField, message: string | null): void {
    const input = form.querySelector<HTMLInputElement | HTMLTextAreaElement>(`[name="${field}"]`);
    const box = form.querySelector<HTMLElement>(`[data-error-for="${field}"]`);
    if (!input || !box) return;
    if (message) {
      box.textContent = message;
      box.hidden = false;
      input.setAttribute('aria-invalid', 'true');
    } else {
      box.textContent = '';
      box.hidden = true;
      input.removeAttribute('aria-invalid');
    }
  }

  function clearErrors(form: HTMLFormElement): void {
    (['name', 'email', 'message'] as SubmissionField[]).forEach((f) => setError(form, f, null));
  }

  function showStatus(form: HTMLFormElement, message: string, tone: 'ok' | 'error'): void {
    const status = form.querySelector<HTMLElement>('[data-status]');
    if (!status) return;
    status.textContent = message;
    status.dataset.tone = tone;
    status.hidden = false;
  }

  function firstInvalid(form: HTMLFormElement, errors: ApiError[]): void {
    const first = form.querySelector<HTMLElement>(`[name="${errors[0]?.field}"]`);
    first?.focus();
  }

  function enhance(form: HTMLFormElement): void {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      clearErrors(form);
      const data = new FormData(form);
      const input = {
        name: String(data.get('name') ?? ''),
        email: String(data.get('email') ?? ''),
        type: String(data.get('type') ?? '') as SubmissionType,
        message: String(data.get('message') ?? ''),
      };
      const company = String(data.get('company') ?? '');

      const clientErrors = validateSubmission(input);
      if (clientErrors.length > 0) {
        clientErrors.forEach((err) => setError(form, err.field, err.message));
        firstInvalid(form, clientErrors);
        return;
      }

      const button = form.querySelector<HTMLButtonElement>('[type="submit"]');
      if (button) button.disabled = true;
      try {
        const res = await fetch('/api/inquiry', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify({ ...input, company }),
        });
        if (res.status === 201) {
          form.reset();
          showStatus(form, "Thanks — we've got your message and will be in touch.", 'ok');
        } else if (res.status === 400) {
          const body = (await res.json().catch(() => ({}))) as { errors?: ApiError[] };
          const errors = body.errors ?? [];
          errors.forEach((err) => setError(form, err.field, err.message));
          firstInvalid(form, errors);
        } else if (res.status === 429) {
          // Values are preserved (no reset) so the user can retry after the window.
          showStatus(form, "You're doing that too often. Please wait a minute and try again.", 'error');
        } else {
          // Values are preserved (no reset) so the user can retry.
          showStatus(form, 'Something went wrong. Please try again.', 'error');
        }
      } catch {
        showStatus(form, 'Network error. Please try again.', 'error');
      } finally {
        if (button) button.disabled = false;
      }
    });
  }

  document.querySelectorAll<HTMLFormElement>('form[data-inquiry]').forEach(enhance);
</script>

<style>
  .inquiry {
    display: grid;
    gap: var(--space-4);
    margin-top: var(--space-4);
    padding: var(--space-4) var(--space-6);
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius);
  }
  .inquiry__field {
    display: grid;
    gap: var(--space-3);
  }
  .inquiry__hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }
  .inquiry__field label {
    font-weight: 500;
  }
  .inquiry__field input,
  .inquiry__field textarea {
    padding: var(--space-3);
    font: inherit;
    color: var(--color-ink);
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius);
  }
  .inquiry__field textarea {
    resize: vertical;
  }
  .inquiry__field input:focus-visible,
  .inquiry__field textarea:focus-visible {
    outline: 2px solid var(--color-cardinal);
    outline-offset: 2px;
  }
  .inquiry__field input[aria-invalid='true'],
  .inquiry__field textarea[aria-invalid='true'] {
    border-color: var(--color-cardinal);
  }
  .inquiry__error {
    margin: 0;
    color: var(--color-cardinal-dark);
    font-size: var(--step-0);
  }
  .inquiry button[type='submit'] {
    justify-self: start;
    padding: var(--space-3) var(--space-6);
    color: var(--color-paper);
    background: var(--color-cardinal);
    border: 1px solid transparent;
    border-radius: var(--radius);
    cursor: pointer;
  }
  .inquiry button[type='submit']:hover {
    background: var(--color-cardinal-dark);
    color: var(--color-paper);
  }
  .inquiry button[type='submit']:disabled {
    opacity: 0.6;
    cursor: progress;
  }
  .inquiry__status {
    margin: 0;
    font-weight: 500;
  }
  .inquiry__status[data-tone='ok'] {
    color: var(--color-cardinal-dark);
  }
  .inquiry__status[data-tone='error'] {
    color: var(--color-cardinal);
  }
</style>

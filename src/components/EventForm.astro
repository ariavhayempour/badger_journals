---
import { MAX_TITLE, MAX_TIME, MAX_LOCATION } from '../lib/limits';
import type { EventField, EventFieldError, EventInput } from '../lib/event-validation';

interface Props {
  action: string; // POST target
  actionValue: string; // hidden _action discriminator (create | update)
  submitLabel: string;
  values?: Partial<EventInput>;
  errors?: EventFieldError[];
}
const { action, actionValue, submitLabel, values = {}, errors = [] } = Astro.props;
const errorFor = (field: EventField): string | undefined => errors.find((e) => e.field === field)?.message;
const errId = (field: EventField): string => `event-${field}-err`;

const field = 'h-10 w-full rounded-lg border border-input bg-background px-3 text-sm shadow-xs outline-none transition-[color,box-shadow] focus-visible:border-ring focus-visible:ring-[3px] focus-visible:ring-ring/50 aria-[invalid=true]:border-destructive aria-[invalid=true]:ring-destructive/20';
---
<form class="grid max-w-2xl gap-5" method="post" action={action}>
  <input type="hidden" name="_action" value={actionValue} />

  <div class="grid gap-1.5">
    <label for="event-date" class="text-sm font-medium">Date</label>
    <input
      id="event-date"
      name="date"
      type="date"
      required
      value={values.date ?? ''}
      class={field}
      aria-describedby={errorFor('date') ? errId('date') : undefined}
      aria-invalid={errorFor('date') ? 'true' : undefined}
    />
    {errorFor('date') && <p class="text-sm text-destructive" id={errId('date')}>{errorFor('date')}</p>}
  </div>

  <div class="grid gap-1.5">
    <label for="event-title" class="text-sm font-medium">Title <span class="font-normal text-muted-foreground">(optional)</span></label>
    <input id="event-title" name="title" type="text" maxlength={MAX_TITLE} value={values.title ?? ''} class={field}
      aria-describedby={errorFor('title') ? errId('title') : undefined} aria-invalid={errorFor('title') ? 'true' : undefined} />
    {errorFor('title') && <p class="text-sm text-destructive" id={errId('title')}>{errorFor('title')}</p>}
  </div>

  <div class="grid gap-1.5">
    <label for="event-time" class="text-sm font-medium">Time <span class="font-normal text-muted-foreground">(optional)</span></label>
    <input id="event-time" name="time" type="text" maxlength={MAX_TIME} value={values.time ?? ''} class={field}
      aria-describedby={errorFor('time') ? errId('time') : undefined} aria-invalid={errorFor('time') ? 'true' : undefined} />
    {errorFor('time') && <p class="text-sm text-destructive" id={errId('time')}>{errorFor('time')}</p>}
  </div>

  <div class="grid gap-1.5">
    <label for="event-location" class="text-sm font-medium">Location <span class="font-normal text-muted-foreground">(optional)</span></label>
    <input id="event-location" name="location" type="text" maxlength={MAX_LOCATION} value={values.location ?? ''} class={field}
      aria-describedby={errorFor('location') ? errId('location') : undefined} aria-invalid={errorFor('location') ? 'true' : undefined} />
    {errorFor('location') && <p class="text-sm text-destructive" id={errId('location')}>{errorFor('location')}</p>}
  </div>

  <button type="submit" class="inline-flex h-10 w-fit items-center justify-center rounded-lg bg-primary px-5 text-sm font-medium text-primary-foreground transition-colors hover:bg-primary/90">{submitLabel}</button>
</form>

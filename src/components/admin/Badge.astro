---
type Variant = 'neutral' | 'join' | 'inquiry' | 'digest' | 'confirmed';
interface Props {
  variant?: Variant;
}
const { variant = 'neutral' } = Astro.props;
const styles: Record<Variant, string> = {
  neutral: 'bg-muted text-muted-foreground',
  join: 'bg-info-tint text-info',
  inquiry: 'bg-muted text-muted-foreground',
  digest: 'bg-cardinal-tint text-cardinal-700',
  confirmed: 'bg-success-tint text-success',
};
---
<span class:list={['inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-xs font-bold whitespace-nowrap', styles[variant]]}>
  <slot />
</span>

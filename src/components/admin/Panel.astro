---
interface Props {
  title: string;
  count?: string;
}
const { title, count } = Astro.props;
---
<section class="mb-6 overflow-hidden rounded-2xl border border-border bg-card shadow-xs">
  <div class="flex flex-wrap items-center justify-between gap-3 border-b border-border/60 px-5 py-4">
    <div class="flex items-baseline gap-3">
      <h2 class="font-serif text-xl font-bold">{title}</h2>
      {count && <span class="text-sm text-muted-foreground">{count}</span>}
    </div>
    <slot name="action" />
  </div>
  <slot />
</section>

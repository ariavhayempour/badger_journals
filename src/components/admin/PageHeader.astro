---
interface Props {
  title: string;
  subtitle?: string;
}
const { title, subtitle } = Astro.props;
---
<div class="mb-7 flex flex-wrap items-end justify-between gap-3">
  <div>
    <h1 class="font-serif text-3xl font-bold tracking-tight">{title}</h1>
    {subtitle && <p class="mt-1 text-muted-foreground">{subtitle}</p>}
  </div>
  <slot name="action" />
</div>

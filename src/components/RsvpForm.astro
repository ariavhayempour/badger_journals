---
interface Props {
  meeting: string; // slug identity; also namespaces element ids so many forms coexist on one page
}
const { meeting } = Astro.props;
const nameId = `rsvp-name-${meeting}`;
const emailId = `rsvp-email-${meeting}`;
const nameErrId = `rsvp-name-err-${meeting}`;
const emailErrId = `rsvp-email-err-${meeting}`;
const statusId = `rsvp-status-${meeting}`;
const dialogId = `rsvp-dialog-${meeting}`;
---
<form class="rsvp" method="post" action="/api/rsvp" novalidate data-rsvp data-meeting={meeting}>
  <p class="rsvp__legend">RSVP for this meeting</p>

  <div class="rsvp__field">
    <label for={nameId}>Name</label>
    <input id={nameId} name="name" type="text" autocomplete="name" required aria-describedby={nameErrId} />
    <p class="rsvp__error" id={nameErrId} data-error-for="name" hidden></p>
  </div>

  <div class="rsvp__field">
    <label for={emailId}>Email (@wisc.edu)</label>
    <input id={emailId} name="email" type="email" autocomplete="email" required aria-describedby={emailErrId} />
    <p class="rsvp__error" id={emailErrId} data-error-for="email" hidden></p>
  </div>

  <input type="hidden" name="meeting" value={meeting} />
  <button type="submit">RSVP</button>

  <p class="rsvp__status" id={statusId} role="status" aria-live="polite" data-status hidden></p>

  <div class="rsvp__modal" id={dialogId} role="dialog" aria-modal="true" aria-labelledby={`${dialogId}-title`} data-modal hidden>
    <div class="rsvp__modal-card">
      <h2 id={`${dialogId}-title`}>You're already registered</h2>
      <p>This email has already RSVP'd for this meeting.</p>
      <button type="button" data-modal-close>Close</button>
    </div>
  </div>
</form>

<script>
  import { validateRsvp, type RsvpField } from '../lib/rsvp-validation';

  type ApiError = { field: RsvpField; message: string };

  function setError(form: HTMLFormElement, field: RsvpField, message: string | null): void {
    const input = form.querySelector<HTMLInputElement>(`[name="${field}"]`);
    const box = form.querySelector<HTMLElement>(`[data-error-for="${field}"]`);
    if (!input || !box) return;
    if (message) {
      box.textContent = message;
      box.hidden = false;
      input.setAttribute('aria-invalid', 'true');
    } else {
      box.textContent = '';
      box.hidden = true;
      input.removeAttribute('aria-invalid');
    }
  }

  function clearErrors(form: HTMLFormElement): void {
    (['name', 'email'] as RsvpField[]).forEach((f) => setError(form, f, null));
  }

  function showStatus(form: HTMLFormElement, message: string, tone: 'ok' | 'error'): void {
    const status = form.querySelector<HTMLElement>('[data-status]');
    if (!status) return;
    status.textContent = message;
    status.dataset.tone = tone;
    status.hidden = false;
  }

  function firstInvalid(form: HTMLFormElement, errors: ApiError[]): void {
    const first = form.querySelector<HTMLInputElement>(`[name="${errors[0]?.field}"]`);
    first?.focus();
  }

  function openModal(form: HTMLFormElement): void {
    const modal = form.querySelector<HTMLElement>('[data-modal]');
    if (!modal) return;
    const restore = document.activeElement as HTMLElement | null;
    modal.hidden = false;
    const focusable = modal.querySelectorAll<HTMLElement>('button, [href], input, [tabindex]:not([tabindex="-1"])');
    const closeBtn = modal.querySelector<HTMLButtonElement>('[data-modal-close]');
    closeBtn?.focus();

    const close = (): void => {
      modal.hidden = true;
      document.removeEventListener('keydown', onKey);
      restore?.focus();
    };
    const onKey = (e: KeyboardEvent): void => {
      if (e.key === 'Escape') {
        close();
      } else if (e.key === 'Tab' && focusable.length > 0) {
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
      }
    };
    document.addEventListener('keydown', onKey);
    closeBtn?.addEventListener('click', close, { once: true });
  }

  function enhance(form: HTMLFormElement): void {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      clearErrors(form);
      const data = new FormData(form);
      const input = {
        name: String(data.get('name') ?? ''),
        email: String(data.get('email') ?? ''),
        meeting: String(data.get('meeting') ?? ''),
      };

      const clientErrors = validateRsvp(input);
      if (clientErrors.length > 0) {
        clientErrors.forEach((err) => setError(form, err.field, err.message));
        firstInvalid(form, clientErrors);
        return;
      }

      const button = form.querySelector<HTMLButtonElement>('[type="submit"]');
      if (button) button.disabled = true;
      try {
        const res = await fetch('/api/rsvp', {
          method: 'POST',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(input),
        });
        if (res.status === 201) {
          form.reset();
          showStatus(form, "You're on the list — see you there!", 'ok');
        } else if (res.status === 409) {
          openModal(form);
        } else if (res.status === 400) {
          const body = (await res.json().catch(() => ({}))) as { errors?: ApiError[] };
          const errors = body.errors ?? [];
          errors.forEach((err) => setError(form, err.field, err.message));
          firstInvalid(form, errors);
        } else {
          // Values are preserved (no reset) so the user can retry.
          showStatus(form, 'Something went wrong. Please try again.', 'error');
        }
      } catch {
        showStatus(form, 'Network error. Please try again.', 'error');
      } finally {
        if (button) button.disabled = false;
      }
    });
  }

  document.querySelectorAll<HTMLFormElement>('form[data-rsvp]').forEach(enhance);
</script>

<style>
  .rsvp {
    display: grid;
    gap: var(--space-4);
    margin-top: var(--space-4);
    padding: var(--space-4) var(--space-6);
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius);
  }
  .rsvp__legend {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--step-1);
  }
  .rsvp__field {
    display: grid;
    gap: var(--space-3);
  }
  .rsvp__field label {
    font-weight: 500;
  }
  .rsvp__field input {
    padding: var(--space-3);
    font: inherit;
    color: var(--color-ink);
    background: var(--color-paper);
    border: 1px solid var(--color-rule);
    border-radius: var(--radius);
  }
  .rsvp__field input:focus-visible {
    outline: 2px solid var(--color-cardinal);
    outline-offset: 2px;
  }
  .rsvp__field input[aria-invalid='true'] {
    border-color: var(--color-cardinal);
  }
  .rsvp__error {
    margin: 0;
    color: var(--color-cardinal-dark);
    font-size: var(--step-0);
  }
  .rsvp button[type='submit'] {
    justify-self: start;
    padding: var(--space-3) var(--space-6);
    color: var(--color-paper);
    background: var(--color-cardinal);
    border: 1px solid transparent;
    border-radius: var(--radius);
    cursor: pointer;
  }
  .rsvp button[type='submit']:hover {
    background: var(--color-cardinal-dark);
    color: var(--color-paper);
  }
  .rsvp button[type='submit']:disabled {
    opacity: 0.6;
    cursor: progress;
  }
  .rsvp__status {
    margin: 0;
    font-weight: 500;
  }
  .rsvp__status[data-tone='ok'] {
    color: var(--color-cardinal-dark);
  }
  .rsvp__status[data-tone='error'] {
    color: var(--color-cardinal);
  }
  .rsvp__modal {
    position: fixed;
    inset: 0;
    display: grid;
    place-items: center;
    padding: var(--space-6);
    background: rgb(0 0 0 / 0.5);
    z-index: 10;
  }
  .rsvp__modal-card {
    max-width: 24rem;
    padding: var(--space-6);
    background: var(--color-paper);
    border-radius: var(--radius);
    box-shadow: var(--shadow-1);
  }
  .rsvp__modal-card h2 {
    margin-top: 0;
  }
  .rsvp__modal-card button {
    margin-top: var(--space-4);
    padding: var(--space-3) var(--space-6);
    color: var(--color-paper);
    background: var(--color-cardinal);
    border: 1px solid transparent;
    border-radius: var(--radius);
    cursor: pointer;
  }
</style>

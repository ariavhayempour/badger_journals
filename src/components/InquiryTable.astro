---
import type { SubmissionRow, SubmissionType } from '../db/schema';
import Badge from './admin/Badge.astro';

interface Props {
  submissions: SubmissionRow[];
}
const { submissions } = Astro.props;

const formatTimestamp = (iso: string): string =>
  new Date(iso).toLocaleString('en-US', { dateStyle: 'medium', timeStyle: 'short' });

const label: Record<SubmissionType, string> = {
  inquiry: 'Inquiry',
  join: 'Join the team',
  digest: 'New digest',
};
const th = 'border-b border-border/60 bg-muted/40 px-5 py-3 text-left text-[0.7rem] font-bold tracking-[0.08em] text-muted-foreground uppercase';
const td = 'border-b border-border/50 px-5 py-3.5 align-top';
---
{
  submissions.length === 0 ? (
    <p class="px-5 py-8 text-muted-foreground">No submissions yet.</p>
  ) : (
    <div class="overflow-x-auto">
      <table class="w-full border-collapse text-sm">
        <thead>
          <tr>
            <th scope="col" class={th}>Name</th>
            <th scope="col" class={th}>Email</th>
            <th scope="col" class={th}>Type</th>
            <th scope="col" class={th}>Message</th>
            <th scope="col" class={th}>Received</th>
            <th scope="col" class={th} aria-label="Actions"></th>
          </tr>
        </thead>
        <tbody>
          {submissions.map((s) => (
            <tr class="transition-colors hover:bg-muted/40 cursor-pointer group" data-id={s.id} data-read={s.is_read ? "true" : "false"}>
              <td class={`${td} ${s.is_read ? 'font-medium text-muted-foreground' : 'font-bold'}`}>
                {!s.is_read && <span class="mr-1.5 inline-block size-2 rounded-full bg-primary" aria-label="Unread"></span>}
                {s.name}
              </td>
              <td class={`${td} text-muted-foreground`}>{s.email}</td>
              <td class={td}><Badge variant={s.submission_type}>{label[s.submission_type]}</Badge></td>
              <td class={`${td} max-w-[40ch] whitespace-pre-wrap ${s.is_read ? 'text-muted-foreground' : 'font-medium'}`}>{s.message}</td>
              <td class={`${td} whitespace-nowrap text-muted-foreground`}>{formatTimestamp(s.created_at)}</td>
              <td class={td}>
                <button type="button" class="text-destructive hover:underline text-xs opacity-0 group-hover:opacity-100 transition-opacity" data-action="delete">Delete</button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )
}

<script>
  document.querySelectorAll<HTMLTableRowElement>('tr[data-id]').forEach(row => {
    row.addEventListener('click', async (e) => {
      const id = row.getAttribute('data-id');
      const target = e.target as HTMLElement;
      
      if (target.closest('[data-action="delete"]')) {
        if (!confirm('Are you sure you want to delete this submission?')) return;
        row.style.opacity = '0.5';
        try {
          const res = await fetch(`/admin/api/submissions/${id}`, { method: 'DELETE' });
          if (res.ok) row.remove();
          else throw new Error();
        } catch {
          alert('Failed to delete submission');
          row.style.opacity = '1';
        }
        return;
      }

      if (row.getAttribute('data-read') === 'false') {
        // Optimistic update
        row.setAttribute('data-read', 'true');
        const nameTd = row.children[0];
        nameTd.className = nameTd.className.replace('font-bold', 'font-medium text-muted-foreground');
        const dot = nameTd.querySelector('span[aria-label="Unread"]');
        if (dot) dot.remove();
        
        const msgTd = row.children[3];
        msgTd.className = msgTd.className.replace('font-medium', 'text-muted-foreground');
        
        fetch(`/admin/api/submissions/${id}`, { method: 'PATCH' }).catch(() => {
           // Silently ignore or revert on error
        });
      }
    });
  });
</script>

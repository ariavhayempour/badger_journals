---
import type { EventRow } from '../db/schema';

interface Props {
  events: EventRow[];
}
const { events } = Astro.props;
---
{
  events.length === 0 ? (
    <p class="empty">No events yet.</p>
  ) : (
    <ul class="event-summary">
      {events.map((e) => (
        <li>
          <time datetime={e.date}>{e.date}</time>
          {e.title && <span class="event-summary__title">{e.title}</span>}
        </li>
      ))}
    </ul>
  )
}
<p class="event-summary__manage"><a href="/admin/events">Manage events</a></p>

<style>
  .empty {
    margin: 0;
    color: var(--color-ink);
    font-style: italic;
  }
  .event-summary {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: var(--space-2);
    font-size: var(--step-0);
  }
  .event-summary li {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    padding-block: var(--space-2);
    border-bottom: 1px solid var(--color-rule);
  }
  .event-summary time {
    font-variant-numeric: tabular-nums;
    font-weight: 500;
  }
  .event-summary__manage {
    margin-block: var(--space-3) 0;
  }
</style>

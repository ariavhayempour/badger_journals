---
// Every entry is a real <a href> so browser back/forward works natively.
import { Image } from 'astro:assets';
import logo from '../assets/images/logo.jpg';

const links = [
  { href: '/meetings', label: 'Meetings' },
  { href: '/mission', label: 'Mission' },
  { href: '/team', label: 'Team' },
  { href: '/create-next-digest', label: 'Create the Next Digest' },
  { href: '/contact', label: 'Contact' },
];
---
<header>
  <nav aria-label="Primary">
    <a href="/" class="brand">
      <Image
        class="brand-logo"
        src={logo}
        alt=""
        width={144}
        height={96}
        format="avif"
        loading="eager"
      />Badger Journals</a>
    <ul>
      {links.map((l) => (
        <li><a href={l.href}>{l.label}</a></li>
      ))}
    </ul>
  </nav>
</header>
<style>
  header {
    background: var(--color-paper);
    border-bottom: 3px solid var(--color-cardinal);
  }
  nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-4) var(--space-6);
    max-width: 68rem;
    margin-inline: auto;
    padding: var(--space-4) var(--space-6);
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    margin-right: auto;
    font-family: var(--font-display);
    font-size: var(--step-3);
    font-weight: 700;
    color: var(--color-cardinal);
    text-decoration: none;
  }
  .brand-logo {
    height: 3rem;
    width: auto;
  }
  nav > ul {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3) var(--space-6);
    margin: 0;
    padding: 0;
    list-style: none;
  }
  nav a {
    text-decoration: none;
    font-weight: 500;
  }
</style>

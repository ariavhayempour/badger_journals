---
// Every entry is a real <a href> so browser back/forward works natively.
import { Image } from 'astro:assets';
import logo from '../assets/images/logo.jpg';
import { buttonVariants } from '@/components/ui/button';
import { cn } from '@/lib/utils';
import MobileNav from './MobileNav';

const links = [
  { href: '/', label: 'Home' },
  { href: '/meetings', label: 'Meetings' },
  { href: '/create-next-digest', label: 'Digests' },
  { href: '/contact', label: 'Contact' },
];

const current = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? current === '/' : current.startsWith(href);
---
<header class="sticky top-0 z-40 border-b border-border bg-background/85 backdrop-blur-md">
  <nav aria-label="Primary" class="mx-auto flex max-w-6xl items-center gap-6 px-6 py-3.5">
    <a href="/" class="mr-auto flex items-center gap-3">
      <Image
        class="h-10 w-auto"
        src={logo}
        alt=""
        width={144}
        height={96}
        format="avif"
        loading="eager"
      />
      <span class="font-serif text-[1.35rem] font-bold tracking-tight text-foreground">Badger Journals</span>
    </a>
    <ul class="hidden items-center gap-7 md:flex">
      {links.map((l) => (
        <li>
          <a
            href={l.href}
            aria-current={isActive(l.href) ? 'page' : undefined}
            class:list={[
              'text-[0.95rem] font-medium transition-colors hover:text-primary',
              isActive(l.href) ? 'text-primary' : 'text-foreground/70',
            ]}
          >{l.label}</a>
        </li>
      ))}
    </ul>
    <a href="/meetings" class={cn(buttonVariants({ variant: 'default' }), 'hidden h-9 px-4 md:inline-flex')}>
      RSVP to a meeting
    </a>
    <MobileNav client:load links={links} />
  </nav>
</header>

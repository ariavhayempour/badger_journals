---
// Self-hosted @fontsource fonts, Latin subset, bundled at build — no external requests (docs/claude/code-notes.md).
import '@fontsource/spectral/latin-500.css';
import '@fontsource/spectral/latin-600.css';
import '@fontsource/spectral/latin-700.css';
import '@fontsource/spectral/latin-800.css';
import '@fontsource/spectral/latin-600-italic.css';
import '@fontsource-variable/hanken-grotesk';
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
  path: string; // canonical path for this page, e.g. '/mission'
}
const { title, description, path } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" type="image/png" href="/favicon-32.png" sizes="32x32" />
    <link rel="icon" type="image/png" href="/favicon-16.png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <SEO title={title} description={description} path={path} />
  </head>
  <body class="min-h-dvh bg-background text-foreground">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

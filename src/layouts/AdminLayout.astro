---
// Admin shell: top bar with site nav + iconed sidebar, distinct from the public BaseLayout.
import '@fontsource/spectral/latin-600.css';
import '@fontsource/spectral/latin-700.css';
import '@fontsource/spectral/latin-800.css';
import '@fontsource-variable/hanken-grotesk';
import '../styles/global.css';
import Header from '../components/Header.astro';
import { type AdminLink } from '../components/AdminNav';
import { listRsvps } from '../db/rsvp';
import { listSubmissions } from '../db/submission';

interface Props {
  title: string;
  rsvpsCount?: number;
  unreadSubmissionsCount?: number;
}
const { title, rsvpsCount: propRsvps, unreadSubmissionsCount: propUnreadSubmissions } = Astro.props;

const rsvpsCount = propRsvps ?? (await listRsvps()).length;
const unreadSubmissionsCount = propUnreadSubmissions ?? (await listSubmissions()).filter((s) => !s.is_read).length;

const current = Astro.url.pathname;
const isActive = (href: string) => (href === '/admin' ? current === '/admin' : current.startsWith(href));

const links: AdminLink[] = [
  { href: '/admin', label: 'Dashboard', icon: 'dashboard', active: isActive('/admin') },
  { href: '/admin/events', label: 'Events', icon: 'events', active: isActive('/admin/events') },
  { href: '/admin/rsvps', label: 'RSVPs', icon: 'rsvps', count: rsvpsCount, active: isActive('/admin/rsvps') },
  { href: '/admin/submissions', label: 'Submissions', icon: 'submissions', count: unreadSubmissionsCount, active: isActive('/admin/submissions') },
];

// Inline icons keep the desktop sidebar server-rendered (no hydration).
const icons: Record<AdminLink['icon'], string> = {
  dashboard: 'M4 13h6V4H4zM14 20h6V4h-6zM4 20h6v-5H4z',
  events: 'M3 5h18v16H3zM3 9h18M8 3v4M16 3v4',
  rsvps: 'M17 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2M9.5 11a4 4 0 1 0 0-8 4 4 0 0 0 0 8M22 21v-2a4 4 0 0 0-3-3.87',
  submissions: 'M4 4h16v16H4zM4 7l8 6 8-6',
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <link rel="preconnect" href="https://clerk.accounts.dev" />
    <title>{title} · Badger Journals Admin</title>
  </head>
  <body class="flex min-h-dvh flex-col bg-canvas text-foreground">
    <Header adminLinks={links} />

    <div class="mx-auto flex w-full max-w-[1440px] flex-1">
      <aside class="hidden w-60 shrink-0 border-r border-sidebar-border bg-sidebar lg:block">
        <nav class="sticky top-4 grid gap-1 p-3">
          <p class="px-3 pt-2 pb-1 text-[0.68rem] font-bold tracking-[0.14em] text-muted-foreground uppercase">Manage</p>
          {links.map((l) => (
            <a
              href={l.href}
              aria-current={l.active ? 'page' : undefined}
              class:list={[
                'flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium transition-colors',
                l.active ? 'bg-sidebar-accent text-sidebar-accent-foreground' : 'text-sidebar-foreground hover:bg-black/[0.04]',
              ]}
            >
              <svg class="size-[18px] shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
                <path d={icons[l.icon]} />
              </svg>
              {l.label}
              <span
                id={l.icon === 'submissions' ? 'nav-submissions-count' : l.icon === 'rsvps' ? 'nav-rsvps-count' : undefined}
                class:list={[
                  'ml-auto grid h-5 min-w-[22px] place-items-center rounded-full px-1.5 text-xs font-bold',
                  l.active ? 'bg-primary text-primary-foreground' : 'bg-black/[0.06] text-muted-foreground',
                  (l.count == null || l.count === 0) && 'hidden',
                ]}
              >{l.count ?? 0}</span>
            </a>
          ))}
        </nav>
      </aside>

      <main class="min-w-0 flex-1 px-5 py-8 sm:px-8">
        <slot />
      </main>
    </div>

    <script>
      const submissionsBadge = document.getElementById('nav-submissions-count');
      if (submissionsBadge) {
        document.addEventListener('submissions:changed', () => {
          const unread = document.querySelectorAll('tr[data-id][data-read="false"]').length;
          submissionsBadge.textContent = String(unread);
          submissionsBadge.classList.toggle('hidden', unread === 0);
        });
      }

      const rsvpsBadge = document.getElementById('nav-rsvps-count');
      if (rsvpsBadge) {
        document.addEventListener('rsvps:changed', () => {
          const total = document.querySelectorAll('tr[data-rsvp-id]').length;
          rsvpsBadge.textContent = String(total);
          rsvpsBadge.classList.toggle('hidden', total === 0);
        });
      }
    </script>
  </body>
</html>

{
  "name": "badger-journals",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "sh -c 'set -a; [ -f .env ] && . ./.env; [ -f .env.local ] && . ./.env.local; set +a; exec astro dev'",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "typecheck": "astro check",
    "test": "vitest run",
    "db:migrate": "node --experimental-strip-types scripts/migrate.ts",
    "db:check": "node --experimental-strip-types scripts/db-check.ts"
  },
  "dependencies": {
    "@astrojs/react": "^6.0.1",
    "@astrojs/vercel": "^8.0.0",
    "@base-ui/react": "^1.6.0",
    "@clerk/astro": "^4.0.0",
    "@fontsource-variable/geist": "^5.3.0",
    "@fontsource-variable/hanken-grotesk": "^5.3.0",
    "@fontsource/spectral": "^5.3.0",
    "@neondatabase/serverless": "^1.0.0",
    "@tailwindcss/vite": "^4.3.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.25.0",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "shadcn": "^4.13.1",
    "sharp": "0.34.5",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "@lhci/cli": "^0.15.1",
    "axe-core": "^4.12.1",
    "jsdom": "^29.1.1",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0"
  }
}
